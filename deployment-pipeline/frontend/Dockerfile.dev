# Development Dockerfile with hot reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose ports (React dev server + Nginx)
EXPOSE 80 3001

# Start both React dev server and Nginx
CMD ["sh", "-c", "npm start & nginx -g 'daemon off;'"]