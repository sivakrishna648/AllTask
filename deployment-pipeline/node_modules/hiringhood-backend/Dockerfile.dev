# Development Dockerfile with hot reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including devDependencies for testing)
RUN npm ci

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start with nodemon for hot reload (if available) or node
CMD ["node", "src/server.js"]